<div id="infoModal" class="fixed inset-0 z-[100] hidden items-center justify-center bg-stone-900/60 backdrop-blur-sm transition-opacity opacity-0 duration-300" aria-labelledby="modal-title" role="dialog" aria-modal="true">
  
  <div class="absolute inset-0 cursor-pointer" onclick="closeModal()"></div>
  
  <div class="relative bg-white dark:bg-[#1a110a] rounded-2xl border border-amber-200/50 dark:border-stone-800 shadow-2xl p-6 sm:p-8 max-w-lg w-full mx-4 transform scale-95 transition-transform duration-300">
    
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-2xl font-extrabold text-stone-900 dark:text-white flex items-center gap-2" id="modal-title">
        <span>🏛️</span> Athena-Devs
      </h3>
      <button onclick="closeModal()" class="text-stone-400 hover:text-stone-700 dark:hover:text-stone-200 transition cursor-pointer p-1">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
      </button>
    </div>
    
    <div class="mb-6 space-y-3 text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
      <p>
        {{ about.description }}
      </p>
      <p>
        Tem um desafio, ideia ou proposta de parceria? Escolha o melhor canal abaixo para conversarmos.
      </p>
    </div>
    
    <div class="space-y-3">
      <a href="mailto:{{ site.email }}" class="flex items-center gap-3 w-full p-3 rounded-lg border border-stone-200 dark:border-stone-800 hover:border-athena-gold dark:hover:border-athena-gold bg-stone-50 dark:bg-stone-900/50 hover:bg-amber-50 dark:hover:bg-athena-dark/30 transition group">
        <span class="text-xl">✉️</span>
        <span class="font-medium text-stone-800 dark:text-stone-200 group-hover:text-athena-gold transition">E-mail Coletivo</span>
      </a>
      <a href="{{ site.github_org }}" target="_blank" class="flex items-center gap-3 w-full p-3 rounded-lg border border-stone-200 dark:border-stone-800 hover:border-athena-gold dark:hover:border-athena-gold bg-stone-50 dark:bg-stone-900/50 hover:bg-amber-50 dark:hover:bg-athena-dark/30 transition group">
        <span class="text-xl">💻</span>
        <span class="font-medium text-stone-800 dark:text-stone-200 group-hover:text-athena-gold transition">GitHub da Organização</span>
      </a>
    </div>
    
  </div>
</div>

<script>
  const modal = document.getElementById('infoModal');
  function getModalBox() {
    return document.getElementById('infoModal').querySelector('.relative');
  }

  function openModal() {
    const m = document.getElementById('infoModal');
    if (!m) return;
    
    m.classList.remove('hidden');
    m.classList.add('flex');
    
    setTimeout(() => {
      m.classList.remove('opacity-0');
      getModalBox().classList.remove('scale-95');
      getModalBox().classList.add('scale-100');
    }, 10);
  }

  function closeModal() {
    const m = document.getElementById('infoModal');
    if (!m) return;
    
    m.classList.add('opacity-0');
    getModalBox().classList.remove('scale-100');
    getModalBox().classList.add('scale-95');
    
    setTimeout(() => {
      m.classList.add('hidden');
      m.classList.remove('flex');
    }, 300);
  }
</script>